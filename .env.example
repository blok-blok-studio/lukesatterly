# Resend — Email & Newsletter
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Resend Audience ID — Create an audience at https://resend.com/audiences
# This is where subscriber contacts are stored for newsletters
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Verified sender email — Must be from a domain verified in Resend
# Use "onboarding@resend.dev" for testing, your own domain for production
RESEND_FROM_EMAIL=hello@coachluki.com
