# Database — Prisma Postgres (free tier)
# Get yours at https://www.prisma.io or use Neon/Supabase
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Resend — Email delivery
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Resend Audience ID — for newsletter subscriber list
# Create at https://resend.com/audiences
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Verified sender email — must be from a domain verified in Resend
RESEND_FROM_EMAIL=hello@coachluki.com

# Reply-to address for outbound emails
RESEND_REPLY_TO=luke.satterly@icloud.com

# Cron secret — protects the /api/cron/sequence endpoint
# Generate: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# HMAC secret for signed unsubscribe tokens — MUST be different from CRON_SECRET
# Generate: openssl rand -hex 32
UNSUBSCRIBE_SECRET=your-unsubscribe-secret-here

# Optional: override the Google Calendar booking URL used in emails
# CALENDAR_URL=https://calendar.app.google/...

# Optional: override the training guide PDF download URL used in emails
# GUIDE_URL=https://coachluki.com/coach-luki-training-guide.pdf
